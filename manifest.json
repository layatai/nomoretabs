{
  "manifest_version": 3,
  "name": "No More Tabs",
  "version": "1.2.0",
  "description": "Close tabs by hostname, close duplicates, or keep a single tab per hostname. Hotkey opens a command palette.",
  "permissions": ["tabs", "tabGroups", "contextMenus", "favicon", "storage", "history"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "No More Tabs"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Open the tab-closing command palette"
    },
    "open-goto-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Open the go-to-tab command palette"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
